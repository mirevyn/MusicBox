# MySQL 配置
# Docker Compose 启动时必须显式填写
MYSQL_ROOT_PASSWORD=your_secure_password_here

# JWT 配置
# Docker Compose 启动时必须显式填写
JWT_SECRET=your_random_jwt_secret_here

# 后端服务配置
MUSICBOX_HTTP_ADDR=:8000
GIN_MODE=release

# CORS 配置（多个来源用逗号分隔）
# Docker + Nginx 同源部署时，通常可以留空
# 如果前后端分离部署，再显式填写真实域名或开发地址
ALLOWED_ORIGINS=

# AI 配置
# 推荐将应用指向共享的外部 Ollama 或 OpenAI 兼容服务。
# 示例：
# AI_BASE_URL=http://192.168.1.10:11434
# AI_BASE_URL=https://your-openai-compatible.example.com/v1
AI_BASE_URL=
AI_MODEL=qwen2.5:7b
# 建议在稳定部署时显式填写 ollama 或 openai
AI_PROVIDER=ollama
AI_API_KEY=
# 默认禁止用户在前端配置内网/本机 AI 地址，避免 SSRF。仅可信内网部署时再开启。
AI_ALLOW_PRIVATE_BASE_URLS=false

# 如果大模型首次冷启动较慢，可以适当调大这个超时时间（单位：秒）
AI_REQUEST_TIMEOUT_SECONDS=300
